(define ffi-doc-body-cache (make-hash))

(define (ffi-doc-body slug)
  (hash-ref! ffi-doc-body-cache slug
             (lambda ()
               (define r (assoc slug ffi-doc-body-string-alist))
               (and r (read (open-input-string (cdr r)))))))

(define (ffi-doc-title slug)
  (define r (assoc slug ffi-doc-title-alist))
  (and r (cdr r)))
