;;;
;;; DOM
;;;

;; This file declares the browser DOM bindings.
;;
;; Return-type convention:
;; - `(extern)` is used for nullable DOM/Web API results, so JS `null` maps to `#f`.
;; - `(extern/raw)` is used when raw JS extern behavior is desired.

(include-ffi "window.ffi")
(include-ffi "performance.ffi")
(include-ffi "document.ffi")
(include-ffi "event.ffi")
(include-ffi "domrect.ffi")
(include-ffi "element.ffi")
(include-ffi "canvas.ffi")
(include-ffi "media.ffi")
(include-ffi "image.ffi")
