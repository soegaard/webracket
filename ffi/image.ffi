;;;
;;; DOM
;;;

;; This file declares the browser DOM bindings.
;;
;; Return-type convention:
;; - `(extern)` is used for nullable DOM/Web API results, so JS `null` maps to `#f`.
;; - `(extern/raw)` is used when raw JS extern behavior is desired.

;;; HTMLImageElement
;;;

;; https://developer.mozilla.org/en-US/docs/Web/API/HTMLImageElement/Image

(define-foreign js-image-new
  #:module "image"
  #:name   "new"
  #:doc    "Creates a new HTMLImageElement."
  #:mdn    "HTMLImageElement/new"
  ;; Pass `(void)` for missing optional arguments; it becomes JS `undefined`.
  (-> (value value) (extern/raw)))

;; Properties
(define-foreign js-image-alt
  #:module "image"
  #:name   "alt"
  #:doc    "Returns the fallback alt text."
  #:mdn    "HTMLImageElement/alt"
  (-> (extern) (string)))

(define-foreign js-set-image-alt!
  #:module "image"
  #:name   "set-alt!"
  #:doc    "Sets the fallback alt text."
  #:mdn    "HTMLImageElement/setAlt"
  (-> (extern string) ()))

(define-foreign js-image-src
  #:module "image"
  #:name   "src"
  #:doc    "Returns the image source URL."
  #:mdn    "HTMLImageElement/src"
  (-> (extern) (string)))

