;; Methods
(define-foreign js-image-decode
  #:module "image"
  #:name   "decode"
  #:doc    "Decodes the image and returns a promise that settles when decoding finishes."
  #:mdn    "HTMLImageElement/decode"
  (-> (extern) (extern/raw)))
