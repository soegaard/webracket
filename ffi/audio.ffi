;;;
;;; Audio
;;;

;; This file declares bindings for the JavaScript Web Audio API.
;; The raw surface stays intentionally narrow: constructors, core graph
;; nodes, numeric properties, and the small set of methods needed to build
;; and inspect an audio graph from WebRacket.

;;;
;;; AudioContext
;;;

;; Create a new AudioContext with the browser defaults.
;; The context options argument is intentionally omitted in this first slice.
;; This binding returns the raw JS AudioContext object.
(define-foreign js-audio-context-new
  #:module "audio"
  #:name   "context-new"
  (-> () (extern/raw)))

;; Close the audio context.
;; ctx : extern
;; Returns the browser Promise returned by AudioContext.close().
(define-foreign js-audio-context-close
  #:module "audio"
  #:name   "context-close"
  (-> (extern) (extern/raw)))

;; Resume the audio context.
;; ctx : extern
;; Returns the browser Promise returned by AudioContext.resume().
(define-foreign js-audio-context-resume
  #:module "audio"
  #:name   "context-resume"
  (-> (extern) (extern/raw)))

;; Suspend the audio context.
;; ctx : extern
;; Returns the browser Promise returned by AudioContext.suspend().
(define-foreign js-audio-context-suspend
  #:module "audio"
  #:name   "context-suspend"
  (-> (extern) (extern/raw)))

;; Read the AudioContext state string.
;; ctx : extern
(define-foreign js-audio-context-state
  #:module "audio"
  #:name   "context-state"
  (-> (extern) (string)))

;; Read the current time of the AudioContext.
;; ctx : extern
(define-foreign js-audio-context-current-time
  #:module "audio"
  #:name   "context-current-time"
  (-> (extern) (f64)))

;; Read the sample rate of the AudioContext.
;; ctx : extern
(define-foreign js-audio-context-sample-rate
  #:module "audio"
  #:name   "context-sample-rate"
  (-> (extern) (f64)))

;; Read the base latency of the AudioContext.
;; ctx : extern
(define-foreign js-audio-context-base-latency
  #:module "audio"
  #:name   "context-base-latency"
  (-> (extern) (f64)))

;; Read the output latency of the AudioContext.
;; ctx : extern
(define-foreign js-audio-context-output-latency
  #:module "audio"
  #:name   "context-output-latency"
  (-> (extern) (f64)))

;; Read the destination AudioNode of the AudioContext.
;; ctx : extern
(define-foreign js-audio-context-destination
  #:module "audio"
  #:name   "context-destination"
  (-> (extern) (extern/raw)))

;; Read the listener associated with the AudioContext.
;; ctx : extern
(define-foreign js-audio-context-listener
  #:module "audio"
  #:name   "context-listener"
  (-> (extern) (extern/raw)))

;; Create a GainNode attached to the AudioContext.
;; ctx : extern
(define-foreign js-audio-context-create-gain
  #:module "audio"
  #:name   "context-create-gain"
  (-> (extern) (extern/raw)))

;; Create an OscillatorNode attached to the AudioContext.
;; ctx : extern
(define-foreign js-audio-context-create-oscillator
  #:module "audio"
  #:name   "context-create-oscillator"
  (-> (extern) (extern/raw)))

;; Create an AudioBufferSourceNode attached to the AudioContext.
