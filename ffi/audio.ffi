  #:module "audio"
  #:name   "context-decode-audio-data"
  (-> (extern value) (extern/raw)))

;;;
;;; AudioNode
;;;

;; Read the owning AudioContext for an AudioNode.
;; node : extern
(define-foreign js-audio-node-context
  #:module "audio"
  #:name   "node-context"
  (-> (extern) (extern/raw)))

;; Connect an AudioNode to another node or AudioParam.
;; node : extern
;; destination : value
;; output-index : value
;; input-index : value
;; Pass (void) for omitted trailing optional arguments.
(define-foreign js-audio-node-connect
  #:module "audio"
  #:name   "node-connect"
  (-> (extern value value value) (extern/raw)))

;; Disconnect an AudioNode from the graph.
;; node : extern
;; destination : value
;; output-index : value
;; input-index : value
;; Pass (void) for omitted trailing optional arguments.
(define-foreign js-audio-node-disconnect
  #:module "audio"
  #:name   "node-disconnect"
  (-> (extern value value value) ()))

