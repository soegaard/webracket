(define-foreign js-jsx-point?
  #:module "jsx-point"
  #:name   "is-point"
  (-> (extern) (boolean)))

;; Properties
;; Distance at which point is captured by attractors
; (js-jsx-point-attractor-distance pt:Extern) -> Flonum
