;;;
;;; JSXGraph
;;;

;;; Board

;; Initialize a JSXGraph board
; (js-jsx-init-board container-id:String attributes:Value) -> Extern
(define-foreign js-jsx-init-board
  #:module "jsx-board"
  #:name   "init-board"
  (-> (string value) (extern/raw)))

;; Create an element on a board
; (js-jsx-board-create board:Extern element-type:String parents:Value attributes:Value) -> Extern
(define-foreign js-jsx-board-create
  #:module "jsx-board"
  #:name   "create"
  (-> (extern string value value) (extern/raw)))

;; Convenience constructors for common geometry elements
; (js-jsx-board-create-point board:Extern parents:Value attributes:Value) -> Extern
(define-foreign js-jsx-board-create-point
  #:module "jsx-board"
  #:name   "create-point"
  (-> (extern value value) (extern/raw)))

; (js-jsx-board-create-line board:Extern parents:Value attributes:Value) -> Extern
(define-foreign js-jsx-board-create-line
  #:module "jsx-board"
  #:name   "create-line"
  (-> (extern value value) (extern/raw)))

; (js-jsx-board-create-segment board:Extern parents:Value attributes:Value) -> Extern
(define-foreign js-jsx-board-create-segment
  #:module "jsx-board"
  #:name   "create-segment"
  (-> (extern value value) (extern/raw)))

; (js-jsx-board-create-circle board:Extern parents:Value attributes:Value) -> Extern
(define-foreign js-jsx-board-create-circle
  #:module "jsx-board"
  #:name   "create-circle"
  (-> (extern value value) (extern/raw)))

; (js-jsx-board-create-intersection board:Extern parents:Value attributes:Value) -> Extern
(define-foreign js-jsx-board-create-intersection
  #:module "jsx-board"
  #:name   "create-intersection"
  (-> (extern value value) (extern/raw)))

; (js-jsx-board-create-text board:Extern parents:Value attributes:Value) -> Extern
(define-foreign js-jsx-board-create-text
  #:module "jsx-board"
  #:name   "create-text"
  (-> (extern value value) (extern/raw)))

;; Update board state and redraw as needed
; (js-jsx-board-update! board:Extern) -> Extern
(define-foreign js-jsx-board-update!
  #:module "jsx-board"
  #:name   "update!"
  (-> (extern) (extern/raw)))

;; Force a full board update
; (js-jsx-board-full-update! board:Extern) -> Extern
(define-foreign js-jsx-board-full-update!
  #:module "jsx-board"
  #:name   "full-update!"
  (-> (extern) (extern/raw)))

;; Remove an object from the board
; (js-jsx-board-remove-object! board:Extern obj:Extern) -> Void
(define-foreign js-jsx-board-remove-object!
  #:module "jsx-board"
  #:name   "remove-object!"
  (-> (extern extern) ()))

;; Suspend automatic board updates
; (js-jsx-board-suspend-update! board:Extern) -> Extern
(define-foreign js-jsx-board-suspend-update!
  #:module "jsx-board"
  #:name   "suspend-update!"
  (-> (extern) (extern/raw)))

;; Resume automatic board updates
; (js-jsx-board-unsuspend-update! board:Extern) -> Extern
(define-foreign js-jsx-board-unsuspend-update!
  #:module "jsx-board"
  #:name   "unsuspend-update!"
  (-> (extern) (extern/raw)))

;;; Point

