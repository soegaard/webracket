(check-equal (dom-node-tag aside-node) 'aside "Aside primitive tag is aside")
(check-equal (node-attr aside-node 'title) "Sidebar" "Aside accepts global attrs")
(check-equal (dom-node-tag footer-node) 'footer "Footer primitive tag is footer")
(check-equal (node-attr footer-node 'data-testid) "site-footer" "Footer accepts data-* attrs")
(check-exn (lambda ()
             (Header #:foo "x" (P "bad")))
           "Header rejects unknown attrs")
(check-exn (lambda ()
             (Footer #:foo "x" (P "bad")))
           "Footer rejects unknown attrs")
(check-exn (lambda ()
             (Aside #:foo "x" (P "bad")))
           "Aside rejects unknown attrs")

;; Form and Label primitives
(define @form-action (@ "/submit"))
(define @label-text (@ "Name"))
(define r-form-label
  (render
   (window
    (Form
     #:action @form-action
     #:method "post"
     (Label @label-text
            #:for "name-input"
            #:aria-label "Name label")
     (P "Body")))))
(define form-node (node-child (renderer-root r-form-label) 0))
(define form-label-node (node-child form-node 0))
(check-equal (dom-node-tag form-node) 'form "Form primitive tag is form")
(check-equal (node-attr form-node 'action) "/submit" "Form supports reactive action")
(check-equal (node-attr form-node 'method) "post" "Form accepts method")
(check-equal (dom-node-tag form-label-node) 'label "Label primitive tag is label")
(check-equal (dom-node-text form-label-node) "Name" "Label content supports observables")
(check-equal (node-attr form-label-node 'for) "name-input" "Label accepts #:for")
(check-equal (node-attr form-label-node 'aria-label) "Name label" "Label accepts aria-* attrs")
(:= @form-action "/save")
(:= @label-text "Full name")
(check-equal (node-attr form-node 'action) "/save" "Form updates reactive action")
(check-equal (dom-node-text form-label-node) "Full name" "Label updates reactive text")
(check-exn (lambda ()
             (Form #:foo "x" (P "bad")))
           "Form rejects unknown attrs")
(check-exn (lambda ()
             (Label "x" #:foo "x"))
           "Label rejects unknown attrs")

;; Ul, Ol, and Li are uppercase primitives with children
(define r-lists
  (render
   (window
    (vpanel
     (Ul
      #:type "disc"
      (Li (Span "One"))
      (Li (Span "Two")))
     (Ol
      #:start 3
      #:reversed #t
      (Li (Span "Third"))
      (Li (Span "Second")))))))
(define lists-panel (node-child (renderer-root r-lists) 0))
(define ul-node (node-child lists-panel 0))
(define ol-node (node-child lists-panel 1))
(define ul-li1 (node-child ul-node 0))
(define ul-li2 (node-child ul-node 1))
(define ol-li1 (node-child ol-node 0))
(check-equal (dom-node-tag ul-node) 'ul "Ul primitive tag is ul")
(check-equal (node-attr ul-node 'type) "disc" "Ul accepts type attr")
(check-equal (dom-node-tag ul-li1) 'li "Ul child Li renders")
(check-equal (dom-node-text (node-child ul-li2 0)) "Two" "Ul second Li child text renders")
(check-equal (dom-node-tag ol-node) 'ol "Ol primitive tag is ol")
(check-equal (node-attr ol-node 'start) 3 "Ol accepts start attr")
(check-equal (node-attr ol-node 'reversed) #t "Ol accepts reversed attr")
(check-equal (dom-node-tag ol-li1) 'li "Ol child Li renders")
(check-exn (lambda ()
             (Ul #:foo "x" (Li (Span "bad"))))
           "Ul rejects unknown attrs")
(check-exn (lambda ()
             (Ol #:foo "x" (Li (Span "bad"))))
           "Ol rejects unknown attrs")
(check-exn (lambda ()
             (Li #:foo "x" (Span "bad")))
           "Li rejects unknown attrs")
