;; H1 keeps class merge/dedupe behavior through root decorators
(define r-h1-class-merge
  (render
   (window
    (vpanel
     (H1 "Class merge"
         #:class '(alpha beta alpha)
         #:attrs '((class gamma) (class beta) (title "ok")))))))
(define h1-class-panel (node-child (renderer-root r-h1-class-merge) 0))
(define h1-class-node  (node-child h1-class-panel 0))
(define h1-class-value (node-attr h1-class-node 'class))
(check-equal (if (or (equal? h1-class-value "alpha beta gamma")
                     (equal? h1-class-value "alpha gamma beta")
                     (equal? h1-class-value "beta alpha gamma")
                     (equal? h1-class-value "beta gamma alpha")
                     (equal? h1-class-value "gamma alpha beta")
                     (equal? h1-class-value "gamma beta alpha"))
                 #t
                 #f)
             #t
             "H1 class values merge and dedupe across #:class and #:attrs")
(check-node-attrs h1-class-node '((title "ok")))

;; H1 supports observable #:style and #:class values on primitive html-element rendering
(define @h1-style (@ "color: red;"))
(define @h1-class (@ "alpha"))
(define r-h1-reactive
  (render
   (window
    (vpanel
     (H1 "Reactive attrs"
         #:style @h1-style
         #:class @h1-class)))))
(define h1-reactive-panel (node-child (renderer-root r-h1-reactive) 0))
(define h1-reactive-node  (node-child h1-reactive-panel 0))
(check-node-attrs h1-reactive-node
                  '((style "color: red;")
                    (class "alpha")))
(:= @h1-style "color: blue;")
(:= @h1-class '(alpha beta))
(check-node-attrs h1-reactive-node
                  '((style "color: blue;")
                    (class "alpha beta")))

;; H1 supports reactive scalar attributes beyond style/class
(define @h1-title (@ "Draft"))
(define @h1-lang (@ "en"))
(define @h1-tabindex (@ 0))
(define @h1-hidden (@ #f))
(define r-h1-reactive-scalars
  (render
   (window
