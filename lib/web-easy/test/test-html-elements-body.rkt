;;;
;;; web-easy HTML Element Tests
;;;

;; Focused tests for primitive HTML element constructors generated by define/element.
;; These tests rely on helper procedures from test-web-easy-body.rkt.

;; Regression: primitive html-element constructors render their real tag on initial render
;; (not fallback div) for leaf and container primitives.
(define r-primitive-initial-tags
  (render
   (window
    (vpanel
     (H1 "Reg H1" #:id "reg-h1")
     (P "Reg P" #:id "reg-p")
     (Span "Reg Span" #:id "reg-span")
     (Img #:src "reg.png" #:alt "Reg Img" #:id "reg-img")
     (Div #:id "reg-div"
          (Span "Div child" #:id "reg-div-child"))))))
(define primitive-initial-tags-panel (node-child (renderer-root r-primitive-initial-tags) 0))
(define reg-h1-node (node-child primitive-initial-tags-panel 0))
(define reg-p-node (node-child primitive-initial-tags-panel 1))
(define reg-span-node (node-child primitive-initial-tags-panel 2))
(define reg-img-node (node-child primitive-initial-tags-panel 3))
(define reg-div-node (node-child primitive-initial-tags-panel 4))
(define reg-div-child-node (node-child reg-div-node 0))
(check-equal (dom-node-tag reg-h1-node) 'h1 "H1 initial primitive tag remains h1 (no div fallback)")
(check-equal (dom-node-tag reg-p-node) 'p "P initial primitive tag remains p (no div fallback)")
(check-equal (dom-node-tag reg-span-node) 'span "Span initial primitive tag remains span (no div fallback)")
(check-equal (dom-node-tag reg-img-node) 'img "Img initial primitive tag remains img (no div fallback)")
(check-equal (dom-node-tag reg-div-node) 'div "Div initial primitive tag remains div")
(check-equal (dom-node-tag reg-div-child-node) 'span "Div child primitive tag remains span")

;; H1 renders as a primitive h1 tag and accepts allowed attributes (including spec-listed align)
(define r-h1-basic
  (render
   (window
    (vpanel
     (H1 "Plain H1"
         #:align "left"
         #:id "hero-title")))))
(define h1-basic-panel (node-child (renderer-root r-h1-basic) 0))
(define h1-basic-node  (node-child h1-basic-panel 0))
(check-equal (dom-node-tag h1-basic-node) 'h1 "H1 primitive tag is h1")
(check-equal (dom-node-text h1-basic-node) "Plain H1" "H1 text content")
(check-equal (node-attr h1-basic-node 'align) "left" "H1 accepts allowed align attribute")
(check-equal (node-attr h1-basic-node 'id) "hero-title" "H1 accepts id as normal attribute")
(check-equal (node-attr h1-basic-node 'data-we-widget) #f "H1 does not use semantic heading widget marker")

;; H2..H6 render primitive heading tags and accept spec-listed align attribute
(define r-hx-basic
  (render
   (window
    (vpanel
     (H2 "H2" #:align "left")
     (H3 "H3" #:align "center")
     (H4 "H4" #:align "right")
     (H5 "H5" #:align "left")
     (H6 "H6" #:align "center")))))
(define hx-panel (node-child (renderer-root r-hx-basic) 0))
(define h2-node (node-child hx-panel 0))
(define h3-node (node-child hx-panel 1))
(define h4-node (node-child hx-panel 2))
(define h5-node (node-child hx-panel 3))
(define h6-node (node-child hx-panel 4))
(check-equal (dom-node-tag h2-node) 'h2 "H2 primitive tag is h2")
(check-equal (dom-node-tag h3-node) 'h3 "H3 primitive tag is h3")
(check-equal (dom-node-tag h4-node) 'h4 "H4 primitive tag is h4")
(check-equal (dom-node-tag h5-node) 'h5 "H5 primitive tag is h5")
(check-equal (dom-node-tag h6-node) 'h6 "H6 primitive tag is h6")
(check-equal (node-attr h2-node 'align) "left" "H2 accepts allowed align attribute")
(check-equal (node-attr h3-node 'align) "center" "H3 accepts allowed align attribute")
(check-equal (node-attr h4-node 'align) "right" "H4 accepts allowed align attribute")

;; H1 rejects unknown attributes early
(check-exn (lambda ()
             (H1 "Bad attr"
                 #:foo "bar"))
           "H1 rejects unknown keyword attribute")
(check-exn (lambda ()
             (H4 "Bad attr"
                 #:foo "bar"))
           "H4 rejects unknown keyword attribute")

;; H1 keeps class merge/dedupe behavior through root decorators
(define r-h1-class-merge
  (render
   (window
    (vpanel
     (H1 "Class merge"
         #:class '(alpha beta alpha)
         #:attrs '((class gamma) (class beta) (title "ok")))))))
(define h1-class-panel (node-child (renderer-root r-h1-class-merge) 0))
(define h1-class-node  (node-child h1-class-panel 0))
(define h1-class-value (node-attr h1-class-node 'class))
(check-equal (if (or (equal? h1-class-value "alpha beta gamma")
                     (equal? h1-class-value "alpha gamma beta")
                     (equal? h1-class-value "beta alpha gamma")
                     (equal? h1-class-value "beta gamma alpha")
                     (equal? h1-class-value "gamma alpha beta")
                     (equal? h1-class-value "gamma beta alpha"))
                 #t
                 #f)
             #t
             "H1 class values merge and dedupe across #:class and #:attrs")
(check-equal (node-attr h1-class-node 'title) "ok" "H1 preserves non-class attrs when merging classes")

;; H1 supports observable #:style and #:class values on primitive html-element rendering
(define @h1-style (@ "color: red;"))
(define @h1-class (@ "alpha"))
(define r-h1-reactive
  (render
   (window
    (vpanel
     (H1 "Reactive attrs"
         #:style @h1-style
         #:class @h1-class)))))
(define h1-reactive-panel (node-child (renderer-root r-h1-reactive) 0))
(define h1-reactive-node  (node-child h1-reactive-panel 0))
(check-equal (node-attr h1-reactive-node 'style) "color: red;" "H1 initial style from observable")
(check-equal (node-attr h1-reactive-node 'class) "alpha" "H1 initial class from observable")
(:= @h1-style "color: blue;")
(:= @h1-class '(alpha beta))
(check-equal (node-attr h1-reactive-node 'style) "color: blue;" "H1 style updates from observable")
(check-equal (node-attr h1-reactive-node 'class) "alpha beta" "H1 class updates from observable")

;; H1 supports reactive scalar attributes beyond style/class
(define @h1-title (@ "Draft"))
(define @h1-lang (@ "en"))
(define @h1-tabindex (@ 0))
(define @h1-hidden (@ #f))
(define r-h1-reactive-scalars
  (render
   (window
    (vpanel
     (H1 "Reactive scalar attrs"
         #:title @h1-title
         #:lang @h1-lang
         #:tabindex @h1-tabindex
         #:hidden @h1-hidden)))))
(define h1-reactive-scalars-panel (node-child (renderer-root r-h1-reactive-scalars) 0))
(define h1-reactive-scalars-node  (node-child h1-reactive-scalars-panel 0))
(check-equal (node-attr h1-reactive-scalars-node 'title) "Draft" "H1 initial title from observable")
(check-equal (node-attr h1-reactive-scalars-node 'lang) "en" "H1 initial lang from observable")
(check-equal (node-attr h1-reactive-scalars-node 'tabindex) 0 "H1 initial tabindex from observable")
(check-equal (node-attr h1-reactive-scalars-node 'hidden) #f "H1 initial hidden from observable")
(:= @h1-title "Published")
(:= @h1-lang "da")
(:= @h1-tabindex 2)
(:= @h1-hidden #t)
(check-equal (node-attr h1-reactive-scalars-node 'title) "Published" "H1 title updates from observable")
(check-equal (node-attr h1-reactive-scalars-node 'lang) "da" "H1 lang updates from observable")
(check-equal (node-attr h1-reactive-scalars-node 'tabindex) 2 "H1 tabindex updates from observable")
(check-equal (node-attr h1-reactive-scalars-node 'hidden) #t "H1 hidden updates from observable")

;; H1 rejects procedure-valued attributes (including via #:attrs escape hatch)
(check-exn (lambda ()
             (H1 "Bad title proc"
                 #:title (lambda () "x")))
           "H1 rejects procedure-valued keyword attrs")
(check-exn (lambda ()
             (H1 "Bad attrs proc"
                 #:attrs (list (list 'title (lambda () "x")))))
           "H1 rejects procedure-valued #:attrs entries")

;; H1 ignores procedure-valued observable attr updates (keeps last valid value)
(define @h1-safe-title (@ "initial"))
(define h1-warning-messages '())
(call-with-web-easy-warning-handler
 (lambda (msg)
   (set! h1-warning-messages
         (cons msg h1-warning-messages)))
 (lambda ()
   (define r-h1-safe-title
     (render
      (window
       (vpanel
        (H1 "Safe title"
            #:title @h1-safe-title)))))
   (define h1-safe-title-panel (node-child (renderer-root r-h1-safe-title) 0))
   (define h1-safe-title-node  (node-child h1-safe-title-panel 0))
   (check-equal (node-attr h1-safe-title-node 'title) "initial" "H1 safe title initial value")
   (:= @h1-safe-title "next")
   (check-equal (node-attr h1-safe-title-node 'title) "next" "H1 safe title valid observable update")
   (:= @h1-safe-title (lambda () "bad"))
   (check-equal (node-attr h1-safe-title-node 'title) "next" "H1 ignores procedure observable update and keeps last valid title")))
(check-equal (if (null? h1-warning-messages) #f #t)
             #t
             "H1 procedure observable update emits warning via warning handler")

