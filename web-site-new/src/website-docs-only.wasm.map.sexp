 \\\"Type\\\") (cell \\\"Meaning\\\")) (row (cell (code \\\"(extern)\\\")) (cell \\\"Raw JavaScript value/object reference (no WebRacket value conversion).\\\")) (row (cell (code \\\"(value)\\\")) (cell \\\"WebRacket value; JS results/inputs are converted through the FFI value bridge.\\\")) (row (cell (code \\\"(boolean)\\\")) (cell \\\"WebRacket boolean (\\\" (code \\\"#t\\\") \\\" / \\\" (code \\\"#f\\\") \\\").\\\")) (row (cell (code \\\"(i32)\\\")) (cell \\\"32-bit integer (often legacy 0/1 booleans in older wrappers).\\\")) (row (cell (code \\\"(f64)\\\")) (cell \\\"Double-precision floating-point number.\\\")) (row (cell (code \\\"(string/symbol)\\\")) (cell \\\"Either a Racket string or symbol (typically property/method name).\\\")) (row (cell (code \\\"()\\\")) (cell \\\"No arguments (in input position) or no return value / void (in output position).\\\"))) (h3 \\\"Conversion Rules\\\") (h4 \\\"JS result converted to WebRacket (\\\" (code \\\"js-send/value\\\") \\\")\\\") (code-block (lang \\\"racket\\\") (text \\\"(define arr (js-array/extern (vector 1 2 3)))\\\\n(js-send/value arr \\\\\\\"slice\\\\\\\" (vector 1))\\\\n;; => #(2 3)\\\")) (h4 \\\"Keep raw JS external value (\\\" (code \\\"js-send/extern\\\") \\\")\\\") (code-block (lang \\\"racket\\\") (text \\\"(define arr (js-array/extern (vector 1 2 3)))\\\\n(define x (js-send/extern arr \\\\\\\"slice\\\\\\\" (vector 1)))\\\\n(external? x)\\\\n;; => #t\\\")) (h4 \\\"Strict boolean vs truthiness (\\\" (code \\\"js-send/boolean\\\") \\\" vs \\\" (code \\\"js-send/truthy\\\") \\\")\\\") (code-block (lang \\\"racket\\\") (text \\\"(define obj (js-eval \\\\\\\"({ a: () => true, b: () => 1 })\\\\\\\"))\\\\n(js-send/boolean obj \\\\\\\"a\\\\\\\" (vector))\\\\n;; => #t\\\\n(js-send/truthy obj \\\\\\\"b\\\\\\\" (vector))\\\\n;; => #t\\\\n;; (js-send/boolean obj \\\\\\\"b\\\\\\\" (vector)) raises, because result is number, not boolean\\\")) (h2 \\\"Chapter 2 — Core Interop Functions\\\") (p \\\"These are the functions you will use most in application code.\\\") (h3 \\\"2.1 Value Properties\\\") (table (header (cell \\\"Function\\\") (cell \\\"Input types\\\") (cell \\\"Output type\\\") (cell \\\"Example\\\") (cell \\\"Use when\\\")) (row (cell (link \\\"`js-global-this`\\\" \\\"https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Global_Objects/globalThis\\\")) (cell (code \\\"()\\\")) (cell (code \\\"(extern)\\\")) (cell (code \\\"(js-global-this)\\\")) (cell \\\"you need the JS global object as an external value.\\\")) (row (cell (link \\\"`js-infinity`\\\" \\\"https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Global_Objects/Infinity\\\")) (cell (code \\\"()\\\")) (cell (code \\\"(f64)\\\")) (cell (code \\\"(js-infinity)\\\")) (cell \\\"you want JS \\\" (code \\\"Infinity\\\") \\\" as a flonum.\\\")) (row (cell (link \\\"`js-nan`\\\" \\\"https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Global_Objects/NaN\\\")) (cell (code \\\"()\\\")) (cell (code \\\"(f64)\\\")) (cell (code \\\"(js-nan)\\\")) (cell \\\"you want JS \\\" (code \\\"NaN\\\") \\\" as a flonum.\\\")) (row (cell (link \\\"`js-null`\\\" \\\"https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Operators/null\\\")) (cell (code \\\"()\\\")) (cell (code \\\"(extern)\\\")) (cell (code \\\"(js-null)\\\")) (cell \\\"an API needs literal JS \\\" (code \\\"null\\\") \\\".\\\")) (row (cell (link \\\"`js-undefined`\\\" \\\"https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Global_Objects/undefined\\\")) (cell (code \\\"()\\\")) (cell (code \\\"(extern)\\\")) (cell (code \\\"(js-undefined)\\\")) (cell \\\"an API needs literal JS \\\" (code \\\"undefined\\\") \\\".\\\"))) (h3 \\\"2.2 Value Predicates\\\") (table (header (cell \\\"Function\\\") (cell \\\"Input types\\\") (cell \\\"Output type\\\") (cell \\\"Example\\\") (cell \\\"Use when\\\")) (row (cell (link \\\"`js-null?`\\\" \\\"https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Operators/null\\\")) (cell (code \\\"(extern)\\\")) (cell (code \\\"(boolean)\\\")) (cell (code \\\"(js-null? (js-null))\\\")) (cell \\\"you need a strict null test (\\\" (code \\\"null\\\") \\\" only).\\\")) (row (cell (link \\\"`js-undefined?`\\\" \\\"https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Global_Objects/undefined\\\")) (cell (code \\\"(extern)\\\")) (cell (code \\\"(boolean)\\\")) (cell (code \\\"(js-undefined? (js-undefined))\\\")) (cell \\\"you need a strict undefined test (\\\" (code \\\"undefined\\\") \\\" only).\\\")) (row (cell (link \\\"`js-nullish?`\\\" \\\"https://developer.mozilla.org/en-US/docs/Glossary/Nullish\\\")) (cell (code \\\"(extern)\\\")) (cell (code \\\"(boolean)\\\")) (cell (code \\\"(js-nullish? (js-undefined))\\\")) (cell \\\"you need a combined null-or-undefined test.\\\")) (row (cell (link \\\"`js-truthy?`\\\" \\\"https://developer.mozilla.org/en-US/docs/Glossary/Truthy\\\")) (cell (code \\\"(extern)\\\")) (cell (code \\\"(boolean)\\\")) (cell (code \\\"(js-truthy? (js-eval \\\\\\\"0\\\\\\\"))\\\")) (cell \\\"you need JS truthiness (\\\" (code \\\"Boolean(x)\\\") \\\") as \\\" (code \\\"#t/#f\\\") \\\".\\\")) (row (cell (link \\\"`js-finite?`\\\" \\\"https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Global_Objects/isFinite\\\")) (cell (code \\\"(f64)\\\")) (cell (code \\\"(boolean)\\\")) (cell (code \\\"(js-finite? 42.0)\\\")) (cell \\\"you need \\\" (code \\\"isFinite\\\") \\\" with a boolean result.\\\")) (row (cell (link \\\"`js-nan?`\\\" \\\"https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Global_Objects/isNaN\\\")) (cell (code \\\"(f64)\\\")) (cell (code \\\"(boolean)\\\")) (cell (code \\\"(js-nan? +nan.0)\\\")) (cell \\\"you need \\\" (code \\\"isNaN\\\") \\\" with a boolean result.\\\"))) (p \\\"In JavaScript, a truthy value is a value that is considered true in a Boolean context. All values are truthy unless they are falsy. Falsy values are \\\" (code \\\"false\\\") \\\", \\\" (code \\\"0\\\") \\\", \\\" (code \\\"-0\\\") \\\", \\\" (code \\\"0n\\\") \\\", \\\" (code \\\"\\\\\\\"\\\\\\\"\\\") \\\", \\\" (code \\\"null\\\") \\\", \\\" (code \\\"undefined\\\") \\\", \\\" (code \\\"NaN\\\") \\\", and \\\" (code \\\"document.all\\\") \\\".\\\") (h3 \\\"2.3 Global Function Properties\\\") (table (header (cell \\\"Function\\\") (cell \\\"Input types\\\") (cell \\\"Output type\\\") (cell \\\"Example\\\") (cell \\\"Use when\\\")) (row (cell (link \\\"`js-eval`\\\" \\\"https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Global_Objects/eval\\\")) (cell (code \\\"(string)\\\")) (cell (code \\\"(extern)\\\")) (cell (code \\\"(js-eval \\\\\\\"({x: 10})\\\\\\\")\\\")) (cell \\\"you must evaluate JS source dynamically.\\\")) (row (cell (link \\\"`js-parse-float`\\\" \\\"https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Global_Objects/parseFloat\\\")) (cell (code \\\"(string)\\\")) (cell (code \\\"(f64)\\\")) (cell (code \\\"(js-parse-float \\\\\\\"3.14abc\\\\\\\")\\\")) (cell \\\"you want JS global \\\" (code \\\"parseFloat\\\") \\\" behavior.\\\")) (row (cell (link \\\"`js-parse-int`\\\" \\\"https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Global_Objects/parseInt\\\")) (cell (code \\\"(string)\\\")) (cell (code \\\"(f64)\\\")) (cell (code \\\"(js-parse-int \\\\\\\"42\\\\\\\")\\\")) (cell \\\"you want JS global \\\" (code \\\"parseInt\\\") \\\" behavior.\\\")) (row (cell (link \\\"`js-decode-uri`\\\" \\\"https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Global_Objects/decodeURI\\\")) (cell (code \\\"(string)\\\")) (cell (code \\\"(string)\\\")) (cell (code \\\"(js-decode-uri \\\\\\\"https://a.test/?q=a%20b\\\\\\\")\\\")) (cell \\\"you decode a full URI string.\\\")) (row (cell (link \\\"`js-decode-uri-component`\\\" \\\"https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Global_Objects/decodeURIComponent\\\")) (cell (code \\\"(string)\\\")) (cell (code \\\"(string)\\\")) (cell 