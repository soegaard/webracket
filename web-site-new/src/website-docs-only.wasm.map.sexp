ting, style updates, and renderer updates\\\")) (p \\\"Assumption in examples: the program is compiled with \\\" (code \\\"--ffi jsxgraph\\\") \\\".\\\") (p \\\"All function names are linked to JSXGraph Point API documentation.\\\") (h3 \\\"Table of Contents\\\") (ul (li (link \\\"Chapter 1 — Introduction\\\" \\\"#chapter-1--introduction\\\")) (li (link \\\"Chapter 2 — Conventions\\\" \\\"#chapter-2--conventions\\\")) (li (link \\\"2.1 Type Legend\\\" \\\"#21-type-legend\\\")) (li (link \\\"2.2 Boolean and Numeric Conventions\\\" \\\"#22-boolean-and-numeric-conventions\\\")) (li (link \\\"2.3 Common Setup Helpers\\\" \\\"#23-common-setup-helpers\\\")) (li (link \\\"Chapter 3 — Predicates\\\" \\\"#chapter-3--predicates\\\")) (li (link \\\"Chapter 4 — Point Properties (Getters)\\\" \\\"#chapter-4--point-properties-getters\\\")) (li (link \\\"Chapter 5 — Point Properties (Setters)\\\" \\\"#chapter-5--point-properties-setters\\\")) (li (link \\\"Chapter 6 — Point Methods\\\" \\\"#chapter-6--point-methods\\\")) (li (link \\\"Chapter 7 — Mini Workflows\\\" \\\"#chapter-7--mini-workflows\\\")) (li (link \\\"Configure Point Snapping\\\" \\\"#configure-point-snapping\\\")) (li (link \\\"Hit-Testing and Projection\\\" \\\"#hit-testing-and-projection\\\")) (li (link \\\"Style and Renderer Refresh\\\" \\\"#style-and-renderer-refresh\\\")) (li (link \\\"Chapter 8 — Coverage Checklist\\\" \\\"#chapter-8--coverage-checklist\\\")) (li (link \\\"Chapter 9 — Alphabetized Index\\\" \\\"#chapter-9--alphabetized-index\\\"))) (h2 \\\"Chapter 2 — Conventions\\\") (h3 \\\"2.1 Type Legend\\\") (table (header (cell \\\"Type\\\") (cell \\\"Meaning\\\")) (row (cell (code \\\"(extern)\\\")) (cell \\\"Raw JavaScript object reference (JSXGraph point object).\\\")) (row (cell (code \\\"(string)\\\")) (cell \\\"JavaScript string mapped to WebRacket string.\\\")) (row (cell (code \\\"(f64)\\\")) (cell \\\"Double-precision floating-point number.\\\")) (row (cell (code \\\"(i32)\\\")) (cell \\\"32-bit integer. In this API it is often used as boolean flag (\\\" (code \\\"0\\\") \\\"/\\\" (code \\\"1\\\") \\\").\\\")) (row (cell (code \\\"(boolean)\\\")) (cell \\\"WebRacket boolean (\\\" (code \\\"#t\\\") \\\" / \\\" (code \\\"#f\\\") \\\").\\\")) (row (cell (code \\\"()\\\")) (cell \\\"No return value / void.\\\"))) (h3 \\\"2.2 Boolean and Numeric Conventions\\\") (ul (li \\\"Several point flags are \\\" (code \\\"(i32)\\\") \\\" instead of \\\" (code \\\"(boolean)\\\") \\\". Use \\\" (code \\\"0\\\") \\\" for false and \\\" (code \\\"1\\\") \\\" for true.\\\") (li \\\"Coordinates and distances are \\\" (code \\\"(f64)\\\") \\\".\\\") (li (code \\\"jsx-point-style\\\") \\\" and infobox digit settings are \\\" (code \\\"(i32)\\\") \\\".\\\")) (h3 \\\"2.3 Common Setup Helpers\\\") (code-block (lang \\\"racket\\\") (text \\\"(define pt  (js-eval \\\\\\\"window.pt\\\\\\\"))\\\\n(define pt2 (js-eval \\\\\\\"window.pt2\\\\\\\"))\\\\n(define el1 (js-eval \\\\\\\"window.el1\\\\\\\"))\\\\n(define el2 (js-eval \\\\\\\"window.el2\\\\\\\"))\\\")) (h2 \\\"Chapter 3 — Predicates\\\") (p \\\"Reference root: \\\" (link \\\"JXG.Point\\\" \\\"https://jsxgraph.org/docs/symbols/JXG.Point.html\\\")) (table (header (cell \\\"Function\\\") (cell \\\"Input types\\\") (cell \\\"Output type\\\") (cell \\\"Example\\\") (cell \\\"Use when\\\")) (row (cell (link \\\"`jsx-point?`\\\" \\\"https://jsxgraph.org/docs/symbols/JXG.Point.html\\\")) (cell (code \\\"(extern)\\\")) (cell (code \\\"(boolean)\\\")) (cell (code \\\"(jsx-point? pt)\\\")) (cell \\\"validate an external object is a JSXGraph point.\\\"))) (h2 \\\"Chapter 4 — Point Properties (Getters)\\\") (p \\\"Reference root: \\\" (link \\\"JXG.Point\\\" \\\"https://jsxgraph.org/docs/symbols/JXG.Point.html\\\")) (table (header (cell \\\"Function\\\") (cell \\\"Input types\\\") (cell \\\"Output type\\\") (cell \\\"Example\\\") (cell \\\"Use when\\\")) (row (cell (link \\\"`jsx-point-attractor-distance`\\\" \\\"https://jsxgraph.org/docs/symbols/JXG.Point.html\\\")) (cell (code \\\"(extern)\\\")) (cell (code \\\"(f64)\\\")) (cell (code \\\"(jsx-point-attractor-distance pt)\\\")) (cell \\\"read the attractor capture distance.\\\")) (row (cell (link \\\"`jsx-point-attractors`\\\" \\\"https://jsxgraph.org/docs/symbols/JXG.Point.html\\\")) (cell (code \\\"(extern)\\\")) (cell (code \\\"(extern)\\\")) (cell (code \\\"(jsx-point-attractors pt)\\\")) (cell \\\"inspect attractor points list.\\\")) (row (cell (link \\\"`jsx-point-attractor-unit`\\\" \\\"https://jsxgraph.org/docs/symbols/JXG.Point.html\\\")) (cell (code \\\"(extern)\\\")) (cell (code \\\"(string)\\\")) (cell (code \\\"(jsx-point-attractor-unit pt)\\\")) (cell \\\"read unit used for attractor distance.\\\")) (row (cell (link \\\"`jsx-point-attract-to-grid`\\\" \\\"https://jsxgraph.org/docs/symbols/JXG.Point.html\\\")) (cell (code \\\"(extern)\\\")) (cell (code \\\"(i32)\\\")) (cell (code \\\"(jsx-point-attract-to-grid pt)\\\")) (cell \\\"check whether attract-to-grid is enabled.\\\")) (row (cell (link \\\"`jsx-point-face`\\\" \\\"https://jsxgraph.org/docs/symbols/JXG.Point.html\\\")) (cell (code \\\"(extern)\\\")) (cell (code \\\"(string)\\\")) (cell (code \\\"(jsx-point-face pt)\\\")) (cell \\\"read point marker face.\\\")) (row (cell (link \\\"`jsx-point-ignored-snap-to-points`\\\" \\\"https://jsxgraph.org/docs/symbols/JXG.Point.html\\\")) (cell (code \\\"(extern)\\\")) (cell (code \\\"(extern)\\\")) (cell (code \\\"(jsx-point-ignored-snap-to-points pt)\\\")) (cell \\\"read ignored points for snapping.\\\")) (row (cell (link \\\"`jsx-point-infobox-digits`\\\" \\\"https://jsxgraph.org/docs/symbols/JXG.Point.html\\\")) (cell (code \\\"(extern)\\\")) (cell (code \\\"(i32)\\\")) (cell (code \\\"(jsx-point-infobox-digits pt)\\\")) (cell \\\"read infobox precision setting.\\\")) (row (cell (link \\\"`jsx-point-show-infobox`\\\" \\\"https://jsxgraph.org/docs/symbols/JXG.Point.html\\\")) (cell (code \\\"(extern)\\\")) (cell (code \\\"(i32)\\\")) (cell (