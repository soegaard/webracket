erted to a WebRacket value.\\\")) (row (cell (link \\\"`js-set!`\\\" \\\"https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Operators/Assignment\\\")) (cell (code \\\"(extern value value)\\\")) (cell (code \\\"()\\\")) (cell (code \\\"(js-set! (js-eval \\\\\\\"({})\\\\\\\") \\\\\\\"x\\\\\\\" 10)\\\")) (cell \\\"you need \\\" (code \\\"obj[key] = value\\\") \\\".\\\")) (row (cell (link \\\"`js-index`\\\" \\\"https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Operators/Property_accessors\\\")) (cell (code \\\"(extern value)\\\")) (cell (code \\\"(value)\\\")) (cell (code \\\"(js-index (js-array/extern (vector 10 20)) 1)\\\")) (cell \\\"you read an indexed value and want conversion.\\\")) (row (cell (link \\\"`js-assign!`\\\" \\\"https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Global_Objects/globalThis\\\")) (cell (code \\\"(string/symbol value)\\\")) (cell (code \\\"()\\\")) (cell (code \\\"(js-assign! \\\\\\\"tmpValue\\\\\\\" 123)\\\")) (cell \\\"you assign to \\\" (code \\\"globalThis[name]\\\") \\\".\\\"))) (h3 \\\"2.5 Construction and Object Helpers\\\") (table (header (cell \\\"Function\\\") (cell \\\"Input types\\\") (cell \\\"Output type\\\") (cell \\\"Example\\\") (cell \\\"Use when\\\")) (row (cell (link \\\"`js-new`\\\" \\\"https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Operators/new\\\")) (cell (code \\\"(extern value)\\\")) (cell (code \\\"(extern)\\\")) (cell (code \\\"(js-new (js-Date) (vector))\\\")) (cell \\\"you need \\\" (code \\\"new Ctor(...args)\\\") \\\".\\\")) (row (cell (link \\\"`js-throw`\\\" \\\"https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Statements/throw\\\")) (cell (code \\\"(value)\\\")) (cell (code \\\"()\\\")) (cell (code \\\"(js-throw \\\\\\\"boom\\\\\\\")\\\")) (cell \\\"you need to throw a JS exception.\\\")) (row (cell (link \\\"`js-this`\\\" \\\"https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Operators/this\\\")) (cell (code \