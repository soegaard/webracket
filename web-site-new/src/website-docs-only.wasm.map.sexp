\\"you expect a numeric result as flonum.\\\"))) (p \\\"Notes:\\\") (ul (li (code \\\"send/extern\\\") \\\" => raw JS result\\\") (li (code \\\"send/value\\\") \\\" => JS result converted via FASL\\\") (li (code \\\"send/boolean\\\") \\\" => strict boolean result; throws on non-boolean\\\") (li (code \\\"send/truthy\\\") \\\" => JS truthiness to 0/1\\\") (li \\\"default \\\" (code \\\"send\\\") \\\" mirrors \\\" (code \\\"send/value\\\"))) (p \\\"Error behavior:\\\") (ul (li (code \\\"js-send/boolean\\\") \\\" raises if the JS method result is not boolean.\\\") (li \\\"JS exceptions thrown by a method call cross the FFI boundary and can be handled with \\\" (code \\\"with-handlers\\\") \\\".\\\")) (code-block (lang \\\"racket\\\") (text \\\"(with-handlers ([exn? (lambda (e) 'caught)])\\\\n  (js-send/extern (js-array/extern (vector 1 2 3)) \\\\\\\"notAMethod\\\\\\\" (vector))\\\\n  'unreachable)\\\\n;; => 'caught\\\")) (h3 \\\"2.7 Type and Operator Helpers\\\") (table (header (cell \\\"Function\\\") (cell \\\"Input types\\\") (cell \\\"Output type\\\") (cell \\\"Example\\\") (cell \\\"Use when\\\")) (row (cell (link \\\"`js-typeof`\\\" \\\"https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Operators/typeof\\\")) (cell (code \\\"(extern)\\\")) (cell (code \\\"(string)\\\")) (cell (code \\\"(js-typeof (js-var \\\\\\\"Math\\\\\\\"))\\\")) (cell \\\"you need JS \\\" (code \\\"typeof\\\") \\\" classification.\\\")) (row (cell (link \\\"`js-value->string`\\\" \\\"https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Global_Objects/String/String\\\")) (cell (code \\\"(extern)\\\")) (cell (code \\\"(string)\\\")) (cell (code \\\"(js-value->string (js-send/extern (js-array/extern (vector 1 2)) \\\\\\\"join\\\\\\\" (vector \\\\\\\",\\\\\\\")))\\\")) (cell \\\"you need JS string coercion for an extern value.\\\")) (row (cell (link \\\"`js-instanceof`\\\" \\\"https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Operators/instanceof\\\")) (