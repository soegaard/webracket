erminal-input\\\") \\\", pass \\\" (code \\\"(void)\\\") \\\" for \\\" (code \\\"was-user-input?\\\") \\\" to use default behavior (\\\" (code \\\"true\\\") \\\").\\\") (li \\\"For \\\" (code \\\"xterm-terminal-register-marker\\\") \\\", pass \\\" (code \\\"(void)\\\") \\\" for \\\" (code \\\"cursor-y-offset\\\") \\\" to use default offset (\\\" (code \\\"0\\\") \\\").\\\") (li \\\"For \\\" (code \\\"xterm-terminal-write\\\") \\\" and \\\" (code \\\"xterm-terminal-writeln\\\") \\\", pass \\\" (code \\\"(void)\\\") \\\" as callback for no callback.\\\") (li (code \\\"xterm-terminal-element\\\") \\\" and \\\" (code \\\"xterm-terminal-textarea\\\") \\\" return \\\" (code \\\"(value)\\\") \\\" and may be \\\" (code \\\"(void)\\\") \\\" until \\\" (code \\\"open\\\") \\\" has been called.\\\") (li (code \\\"xterm-fit-addon-propose-dimensions\\\") \\\" returns \\\" (code \\\"(value)\\\") \\\" and may be \\\" (code \\\"(void)\\\") \\\" when dimensions cannot be computed.\\\")) (h3 \\\"2.3 Common Setup Helpers\\\") (code-block (lang \\\"racket\\\") (text \\\"(define term (xterm-terminal-new (void)))\\\\n(define host-el (js-ref/document-by-id \\\\\\\"terminal\\\\\\\"))\\\\n(define fit (xterm-fit-addon-new))\\\\n(define options (js-eval \\\\\\\"({ cursorBlink: true })\\\\\\\"))\\\\n(define handler (js-eval \\\\\\\"(ev) => true\\\\\\\"))\\\")) (h2 \\\"Chapter 3 — Terminal Construction\\\") (p \\\"xterm.js Terminal API: \\\" (link \\\"Terminal\\\" \\\"https://xtermjs.org/docs/api/terminal/classes/terminal/\\\")) (table (header (cell \\\"Function\\\") (cell \\\"Input types\\\") (cell \\\"Output type\\\") (cell \\\"Example\\\") (cell \\\"Use when\\\")) (row (cell (link \\\"`xterm-terminal-new`\\\" \\\"https://xtermjs.org/docs/api/terminal/classes/terminal/\\\")) (cell (code \\\"(value)\\\")) (cell (code \\\"(extern)\\\")) (cell (code \\\"(xterm-terminal-new options)\\\")) (cell \\\"create a new Terminal instance.\\\"))) (h2 \\\"Chapter 4 — Terminal Properties\\\") (p \\\"xterm.js